# ============================================
# AiorWot — API Keys Configuration
# ============================================
# Copy this file to .env and fill in your API keys.
# You need AT LEAST ONE key. More keys = better fallback.
# All providers below have FREE tiers.

# Google Gemini (recommended) — Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (very fast) — Get key at: https://console.groq.com/keys
GROQ_API_KEY=

# Cohere — Get key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# OpenRouter (access to many models) — Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
